{
  "name": "feedhub",
  "version": "0.1.0",
  "private": true,
  "description": "Unified newsletter + RSS hub for Gökhan Turhan — CF Worker (D1 + DO + Queues + KV) + Resend email + XMTP.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "d1:schema": "wrangler d1 execute feedhub --remote --file schema.sql",
    "d1:schema:local": "wrangler d1 execute feedhub --local --file schema.sql",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260601.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.20.0"
  },
  "dependencies": {
    "viem": "^2.54.3"
  }
}
